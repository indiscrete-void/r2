package aura
version = 0.0.1
brief = "Integrate local and remote 🪄"

sourcedir = "src"
executable = "main.js"
opts = "--cg javascript"

depends = json

modules = Aura.Addr
        , Aura.PubSub
        , Aura.Device
        , Aura.WebSocket
        , Aura.Router
        , Aura.Linking
main = Aura.Main
